# .env.example — copy to `.env` and fill in to enable Telegram reporting.
# Leave empty (or delete the file) to keep reports console-only.

# Telegram Bot API (recommended). Create a bot via @BotFather, then send /start
# to your new bot from the chat where you want reports delivered.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Message format: HTML | Markdown | (empty for plain text)
TELEGRAM_PARSE_MODE=HTML

# ── Optional overrides ──────────────────────────────────────────────────────
# API root (override for testnet, etc.)
# ALLOX_API_BASE=https://api.allox.ai/v1

# Comma-separated RSS feeds
# RSS_FEEDS=https://cointelegraph.com/rss,https://decrypt.co/feed

# Pipe-separated prompt templates ({title} is the placeholder)
# PROMPT_TEMPLATES=Explain this headline: {title}|Your take on: {title}?
